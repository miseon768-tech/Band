<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.classroom.domain.classroomMember.mapper.ClassroomMemberMapper">
    <insert id="insertOne" parameterType="classroomMember">
        insert into classroom_member(classroom_id,student_id)
                            values(#{classroomId}, #{studentId})
    </insert>
    <select id="selectByClassroomIdAndStudentId"
            resultType="classroomMember" parameterType="map">
        select * from classroom_member where classroom_id=#{classroomId} and student_id=#{studentId}
    </select>

    <select id="selectStudentIdByClassroomId" parameterType="string" resultType="string">
        select student_id from classroom_member where classroom_id=#{classroomId}
    </select>

    <!-- daily check 쪽 -->
    <insert id="insertDailyCheck" parameterType="dailyCheck">
        insert into daily_check(classroom_member_id, checked_at)
            values(#{classroomMemberId}, #{checkedAt} )
    </insert>
    <select id="existTodayDailyCheckByClassroomMemberId"
            parameterType="int" resultType="boolean">
        select count(*) = 1 as flag from daily_check
            where classroom_member_id=#{classroomMemberId}
                and checked_at=current_date()
    </select>






</mapper>